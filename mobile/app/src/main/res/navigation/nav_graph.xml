<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.ace.krishinetra_mobile.ui.home.HomeFragment"
        android:label="@string/nav_home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_analyze"
            app:destination="@id/analyzeFragment"
            app:enterAnim="@anim/slide_up"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/slide_down" />
        <action
            android:id="@+id/action_home_to_chat"
            app:destination="@id/chatFragment"
            app:enterAnim="@anim/slide_up"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/slide_down" />
        <action
            android:id="@+id/action_home_to_learn"
            app:destination="@id/learnFragment" />
        <action
            android:id="@+id/action_home_to_history"
            app:destination="@id/historyFragment" />
    </fragment>

    <fragment
        android:id="@+id/learnFragment"
        android:name="com.ace.krishinetra_mobile.ui.learn.LearnFragment"
        android:label="Learn"
        tools:layout="@layout/fragment_learn">
        <action
            android:id="@+id/action_learn_to_detail"
            app:destination="@id/learnDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/learnDetailFragment"
        android:name="com.ace.krishinetra_mobile.ui.learn.LearnDetailFragment"
        android:label="Disease Details"
        tools:layout="@layout/fragment_learn_detail" />

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.ace.krishinetra_mobile.ui.history.HistoryFragment"
        android:label="History"
        tools:layout="@layout/fragment_history">
        <action
            android:id="@+id/action_history_to_detail"
            app:destination="@id/historyDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/historyDetailFragment"
        android:name="com.ace.krishinetra_mobile.ui.history.HistoryDetailFragment"
        android:label="Report Details"
        tools:layout="@layout/fragment_history_detail" />

    <fragment
        android:id="@+id/analyzeFragment"
        android:name="com.ace.krishinetra_mobile.ui.analyze.AnalyzeFragment"
        android:label="@string/nav_analyze"
        tools:layout="@layout/fragment_analyze">
        <action
            android:id="@+id/action_analyze_to_home"
            app:destination="@id/homeFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/slide_down" />
    </fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.ace.krishinetra_mobile.ui.chat.ChatFragment"
        android:label="@string/nav_chat"
        tools:layout="@layout/fragment_chat">
        <action
            android:id="@+id/action_chat_to_home"
            app:destination="@id/homeFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/slide_down" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.ace.krishinetra_mobile.ui.profile.ProfileFragment"
        android:label="@string/nav_profile"
        tools:layout="@layout/fragment_profile" />

</navigation>
